{
	"layer": "top",
    "position": "top",
    "height": 40,

	"modules-left": [
        "temperature",
        "cpu",
        "memory",
        "disk"
    ],
	"modules-center": ["clock", "hyprland/workspaces"],
	"modules-right": [
        "pulseaudio",
        "network",
        "bluetooth",
        "battery"],
	
	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "<span font='11'>󰝟 </span> {volume}%",
		"on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"format-icons": {
			"default": [
                "<span font='11'></span>", 
                "<span font='11'></span>", 
                "<span font='11'></span>"
            ]
		}
	},

    "hyprland/workspaces": {
	    "format": "{name}",
        "on-click": "activate"
    },

    "bluetooth": {
        "format": "",
        "format-connected": " {device_alias}",
        "format-connected-battery": " {device_alias} {device_battery_percentage}%",
        "format-no-controller": "󰂲"
    },

	"network": {
		"tooltip": false,
		"format-wifi": "{essid} ({signalStrength}%) <span font='11'>󰖩 </span> ",
		"format-ethernet": "{essid} <span font='11'>󰖩 </span>",
        "format-disconnected": "Disconnected <span font='11'>󰖪 </span>",
        "interval": 30
	},

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 10
        },
        "format": "{icon}  <span>{capacity}%</span>",
        "format-charging": "<span></span> <span>{capacity}%</span>",
        "format-plugged": " <span>{capacity}</span>%",
        "format-alt": "<span>{time}</span> {icon}",
        "format-icons": [
            "<span font='11'></span>", 
            "<span font='11'></span>", 
            "<span font='11'></span>", 
            "<span font='11'></span>", 
            "<span font='11'></span>"
        ]
    },

	"clock": {
        "interval": 60,
        "tooltip": true,
        "format": "{:%I:%M}"
    },

    "cpu": {
        "format": "<span font='11'></span>  {usage}%"
    },

    "memory": {
        "format": "<span font='11'></span>  {}%"
    },

    "temperature": {
        "format": "<span font='11'></span> {temperatureC}°C",
        "critical-threshold": 80
    },

    "disk": {
        "format": "<span font='11'></span> {percentage_used}%",
        "path": "/"
    }
}